# ── Required ──────────────────────────────────────────────────────────────────

# Fordefi API token for calling the approve/abort endpoints.
# Generate one under Settings → API Users in the Fordefi web console.
FORDEFI_API_TOKEN=

# This bot's Fordefi user ID (UUID). Used to confirm the bot is listed as
# a pending approver before acting on a transaction.
# Find it under Settings → Users in the Fordefi web console.
BOT_USER_ID=

# ── Optional ──────────────────────────────────────────────────────────────────

# Webhook secret — reserved for future use; not currently consumed by the
# ECDSA verification flow. Safe to leave empty.
WEBHOOK_SECRET=

# TCP port for the uvicorn HTTP server (default: 8000).
# COSIGNER_PORT=8000

# Override the Fordefi API base URL (useful for staging environments).
# FORDEFI_API_BASE_URL=https://api.fordefi.com

# Source IP that Fordefi webhook deliveries originate from.
# Override only if Fordefi changes their egress IP.
# ALLOWED_IP=54.243.103.88

# Set to "true" to bypass the IP whitelist check.
# Required when running behind ngrok or similar local-tunnel tools.
# NEVER set this in production.
# DISABLE_IP_CHECK=false
